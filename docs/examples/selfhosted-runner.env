# Self-hosted single-slot embedded helper runner behind private ingress.
AONOHAKO_DEPLOYMENT_TARGET=selfhosted
AONOHAKO_EXECUTION_TRANSPORT=embedded
AONOHAKO_SANDBOX_BACKEND=helper
AONOHAKO_INBOUND_AUTH=bearer
AONOHAKO_API_BEARER_TOKEN=replace-with-strong-token
AONOHAKO_WORK_ROOT=/var/lib/aonohako/work
AONOHAKO_MAX_ACTIVE_RUNS=1
AONOHAKO_MAX_PENDING_QUEUE=16
AONOHAKO_MAX_ACTIVE_STREAMS=64
AONOHAKO_MAX_PRINCIPAL_ACTIVE_STREAMS=16
AONOHAKO_MAX_PRINCIPAL_REQUESTS_PER_MINUTE=60
AONOHAKO_TRUSTED_RUNNER_INGRESS=true
AONOHAKO_ALLOW_REQUEST_NETWORK=false
# Optional when a writable cgroup v2 parent is delegated to this service:
# AONOHAKO_CGROUP_PARENT=/sys/fs/cgroup/aonohako
